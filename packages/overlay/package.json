{
  "name": "@silent-build/overlay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/Root.tsx",
    "render": "tsx src/render-cli.ts",
    "render:dashboard": "tsx src/render-cli.ts --composition Dashboard",
    "render:intro": "tsx src/render-cli.ts --composition Intro",
    "render:outro": "tsx src/render-cli.ts --composition Outro",
    "render:phase": "tsx src/render-cli.ts --composition PhaseTransition",
    "render:thumb": "tsx src/render-cli.ts --composition Thumbnail --format png --max-frames 1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.200",
    "@remotion/cli": "^4.0.200",
    "@remotion/google-fonts": "^4.0.451",
    "@remotion/renderer": "^4.0.200",
    "@silent-build/shared": "workspace:*",
    "commander": "^12.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.200"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.0"
  }
}
